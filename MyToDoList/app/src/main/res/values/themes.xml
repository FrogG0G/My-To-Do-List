<resources xmlns:tools="http://schemas.android.com/tools">
    <!-- Базовая тема приложения -->
    <style name="Base.Theme.MyToDoList" parent="Theme.MaterialComponents.DayNight.NoActionBar">
        <!-- Основные цвета приложения (теперь они зафиксированы) -->
        <item name="colorPrimary">@color/primary_blue</item>
        <item name="colorPrimaryVariant">@color/primary_blue</item>
        <item name="colorOnPrimary">@color/white</item>
        <!-- Вторичные цвета (для кнопок и акцентов) -->
        <item name="colorSecondary">@color/cyan_button</item>
        <item name="colorSecondaryVariant">@color/cyan_button</item>
        <item name="colorOnSecondary">@color/white</item>
        
        <!-- Отключаем вмешательство системы в цвета -->
        <item name="android:navigationBarColor">@color/black</item>
        <item name="android:windowBackground">@color/background_light</item>
    </style>

    <style name="Theme.MyToDoList" parent="Base.Theme.MyToDoList" />

    <!-- Стили для настроек -->
    <style name="SettingsItem">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:background">@drawable/settings_item_background</item>
        <item name="android:padding">12dp</item>
        <item name="android:textColor">@color/black</item>
        <item name="android:textSize">16sp</item>
    </style>

    <style name="SettingsItem.Selected" parent="SettingsItem">
        <item name="android:background">@drawable/settings_item_selected</item>
        <item name="android:textColor">@color/primary_blue</item>
    </style>
</resources>